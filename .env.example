# Environment Variables for Netlify Functions
# Copy this file to .env for local development with Netlify CLI

# Authentication Credentials
AUTH_USERNAME=admin
AUTH_PASSWORD=hybrid2026

# JWT Secret Key (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-something-random

# Instructions:
# 1. Copy this file to .env (it's already in .gitignore)
# 2. Update the values above with your desired credentials
# 3. For production, set these in Netlify Dashboard:
#    Site configuration > Environment variables
# 4. Generate a strong JWT_SECRET using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
